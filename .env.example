# Google OAuth (get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-client-id-here

# Google Picker API (for folder selection in setup wizard)
VITE_GOOGLE_API_KEY=your-api-key-here

# Service Account (optional, dev-only - path to SA JSON from Google Cloud)
# VITE_SA_CREDENTIALS_FILE=path/to/service-account.json


# Hardcoded Drive folder for dev login (optional, dev-only - folder with fixtures shared with SA)
# VITE_SA_FOLDER_ID=your-folder-id-here
