# Google OAuth (get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-client-id-here

# Google Picker API (for folder selection in setup wizard)
VITE_GOOGLE_API_KEY=your-api-key-here

# CSV backend for dev/test (no Google API needed)

# Local CSV fixture folder (dev/E2E). When set, wizard opens this folder directly without picker.
VITE_LOCAL_CSV_FIXTURE_FOLDER=happy-path
